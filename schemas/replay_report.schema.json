{
  "$id": "provenance://schemas/replay_report/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "created_utc": {
      "type": "string"
    },
    "replay_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "pattern": "^1$",
      "type": "string"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "ERROR"
      ],
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "verdict",
    "checks",
    "replay_id"
  ],
  "title": "ReplayReport",
  "type": "object"
}